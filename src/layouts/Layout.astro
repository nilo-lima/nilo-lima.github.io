---
import '@fontsource/inter/400.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/700.css';

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
	lang?: 'pt-BR' | 'en';
	articleJsonLd?: Record<string, unknown>;
	breadcrumbJsonLd?: Record<string, unknown>;
}

const {
	title,
	description,
	ogImage = "/og.png",
	lang = 'pt-BR',
	articleJsonLd,
	breadcrumbJsonLd,
} = Astro.props;

const defaultDescription = lang === 'en'
	? "Nilo Lima Jr: IT Manager & DevOps/Cloud/AI specialist. Multi-cloud (AWS · Azure · GCP · OCI), Kubernetes, GitOps and AI applied to infrastructure."
	: "Nilo Lima Jr: Portfólio estratégico de Gestor de TI e Especialista em DevOps, Cloud (AWS · Azure · GCP · OCI), Kubernetes e IA aplicada a infraestrutura.";

const finalDescription = description ?? defaultDescription;

const siteUrl = Astro.site ?? new URL("https://nilo-lima.github.io");
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogLocale = lang === 'en' ? 'en_US' : 'pt_BR';
const ogImageUrl = new URL(ogImage, siteUrl).toString();

// hreflang alternates
const ptHref = new URL('/', siteUrl).toString();
const enHref = new URL('/en/', siteUrl).toString();

// JSON-LD Person schema for rich results
const personJsonLd = {
	"@context": "https://schema.org",
	"@type": "Person",
	name: "Nilo Lima Jr",
	url: siteUrl.toString(),
	jobTitle: lang === 'en' ? "IT Manager & DevOps/Cloud/AI Specialist" : "Gestor de TI & Especialista DevOps/Cloud/IA",
	description: defaultDescription,
	sameAs: [
		"https://www.linkedin.com/in/nilolima/",
		"https://github.com/nilo-lima",
		"https://www.credly.com/users/nilo-lima-jr/badges",
	],
	knowsAbout: [
		"DevOps", "Cloud Computing", "AWS", "Azure", "Google Cloud", "Oracle Cloud",
		"Terraform", "Kubernetes", "Docker", "GitOps", "CI/CD", "Linux",
		"Infrastructure as Code", "Site Reliability Engineering",
		"Artificial Intelligence", "LLM Ops"
	],
	address: {
		"@type": "PostalAddress",
		addressLocality: "Canoas",
		addressRegion: "RS",
		addressCountry: "BR"
	}
};
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={finalDescription} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="author" content="Nilo Lima Jr" />
		<meta name="theme-color" content="#050505" />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={canonical} />
		<link rel="alternate" hreflang="pt-BR" href={ptHref} />
		<link rel="alternate" hreflang="en" href={enHref} />
		<link rel="alternate" hreflang="x-default" href={ptHref} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="alternate" type="application/rss+xml" title="Nilo Lima Jr — Blog" href="/rss.xml" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={finalDescription} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:type" content="image/png" />
		<meta property="og:site_name" content="Nilo Lima Jr" />
		<meta property="og:locale" content={ogLocale} />
		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={finalDescription} />
		<meta name="twitter:image" content={ogImageUrl} />
		<meta name="twitter:image:alt" content="Nilo Lima Jr — Gestor de TI & Especialista DevOps · Cloud · IA" />
		<!-- JSON-LD Person -->
		<script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
		<!-- JSON-LD Article (posts individuais) -->
		{articleJsonLd && (
			<script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
		)}
		<!-- JSON-LD Breadcrumb -->
		{breadcrumbJsonLd && (
			<script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
		)}
		<!-- Goatcounter analytics — privacy-first, sem cookies, LGPD-friendly -->
		<!-- Criar conta em goatcounter.com com código "nilo-lima" se ainda não existir -->
		<script data-goatcounter="https://nilo-lima.goatcounter.com/count"
			async src="//gc.zgo.at/count.js"></script>
	</head>
	<body class="bg-background text-accent font-sans selection:bg-primary/30 selection:text-primary">
		<a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[60] focus:bg-primary focus:text-background focus:px-3 focus:py-2 focus:font-mono focus:text-xs">
			{lang === 'en' ? 'Skip to content' : 'Pular para o conteúdo'}
		</a>
		<div class="fixed inset-0 -z-10 bg-[radial-gradient(circle_at_50%_50%,rgba(56,189,248,0.03)_0,transparent_50%)]"></div>
		<slot />
		<footer data-pagefind-ignore="all" class="border-t border-primary/5 py-6 px-6 mt-auto">
			<div class="max-w-5xl mx-auto flex flex-wrap justify-between items-center gap-4">
				<div class="flex flex-wrap items-center gap-5 text-[11px] font-mono text-secondary/50">
					<a href="https://www.linkedin.com/in/nilolima/" target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors uppercase tracking-widest">LinkedIn</a>
					<a href="https://github.com/nilo-lima" target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors uppercase tracking-widest">GitHub</a>
					<a href="https://www.credly.com/users/nilo-lima-jr/badges" target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors uppercase tracking-widest">Credly</a>
					<a href="https://www.credential.net/profile/nilohernandezdelimajunior896171/wallet" target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors uppercase tracking-widest">Accredible</a>
					<a href="mailto:nilo.lima@gmail.com" class="hover:text-primary transition-colors uppercase tracking-widest">Email</a>
					<a href="/rss.xml" class="hover:text-primary transition-colors uppercase tracking-widest">RSS</a>
					<a href="/now" class="hover:text-primary transition-colors tracking-widest">/now</a>
				</div>
				<span class="text-[11px] font-mono text-secondary/30">© {new Date().getFullYear()} Nilo Lima Jr</span>
			</div>
		</footer>
		<button
			id="back-to-top"
			aria-label="Voltar ao topo"
			class="fixed bottom-6 right-6 z-50 w-9 h-9 border border-primary/30 bg-background/90 backdrop-blur text-primary font-mono text-xs hover:border-primary transition-all opacity-0 pointer-events-none flex items-center justify-center"
		>
			↑
		</button>
		<style is:global>
			:root {
				color-scheme: dark;
			}
			body {
				scrollbar-width: thin;
				scrollbar-color: #38bdf8 #050505;
			}
			::-webkit-scrollbar {
				width: 6px;
			}
			::-webkit-scrollbar-track {
				background: #050505;
			}
			::-webkit-scrollbar-thumb {
				background: #38bdf8;
				border-radius: 10px;
			}
			/* WCAG 2.3.3: respeita preferência de movimento reduzido */
			@media (prefers-reduced-motion: reduce) {
				html {
					scroll-behavior: auto !important;
				}
				*, *::before, *::after {
					animation-duration: 0.001ms !important;
					animation-iteration-count: 1 !important;
					transition-duration: 0.001ms !important;
					scroll-behavior: auto !important;
				}
			}
			/* Foco visível para usuários de teclado (WCAG 2.4.7) */
			:focus-visible {
				outline: 2px solid #38BDF8;
				outline-offset: 3px;
			}
		</style>
		<script>
			const btn = document.getElementById('back-to-top');
			if (btn) {
				window.addEventListener('scroll', () => {
					const visible = window.scrollY > 400;
					btn.style.opacity = visible ? '1' : '0';
					btn.style.pointerEvents = visible ? 'auto' : 'none';
				}, { passive: true });
				btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
			}

			document.addEventListener('keydown', (e) => {
				const tag = (e.target as HTMLElement).tagName;
				const editable = (e.target as HTMLElement).isContentEditable;
				if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT' || editable) return;
				if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
					e.preventDefault();
					window.location.href = '/busca';
				}
			});
		</script>
	</body>
</html>
