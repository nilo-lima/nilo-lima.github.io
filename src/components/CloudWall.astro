---
import { t, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = 'pt-BR' } = Astro.props;
const s = t(lang).certs;
const sectionId = lang === 'en' ? 'certifications' : 'certificacoes';
const MS_LEARN_PROFILE = 'https://learn.microsoft.com/pt-br/users/nilolima-9821/';
const CREDLY_PROFILE   = 'https://www.credly.com/users/nilo-lima-jr/badges';
const ACCREDIBLE_PROFILE = 'https://www.credential.net/profile/nilohernandezdelimajunior896171/wallet';

// Preencha aqui as certificações que quer destacar.
// Formato: { name, issuer, year }
const certs: { name: string; issuer: string; year: string }[] = [
  // Exemplo:
  { name: "Data Protection Officer (DPO)", issuer: "ITCERTS", year: "2026" },   
  { name: "ISO 27001 Foundation", issuer: "ITCERTS", year: "2026" },
  { name: "ISO 20000 Foundation", issuer: "ITCERTS", year: "2026" },
  { name: "ISO 20000 Lead Implementer", issuer: "ITCERTS", year: "2026" },
  { name: "OCI Foundations", issuer: "Oracle", year: "2025" }, 
  { name: "DevOps Advanced", issuer: "Certiprof", year: "2025" },
  { name: "Ethical Hacking", issuer: "Certiprof", year: "2025" },  
  { name: "Multicloud Network Associate", issuer: "Aviatrix", year: "2025" },
  { name: "GitHub Foundations", issuer: "GitHub", year: "2025" },  
  { name: "Software Project Leader", issuer: "Certiprof", year: "2025" },  
  { name: "Help Desk Professional", issuer: "Certiprof", year: "2025" },     
  { name: "Service Desk Leader", issuer: "Certiprof", year: "2025" },    
];
---
<section id={sectionId} class="py-16 px-6 max-w-5xl mx-auto border-t border-primary/10">
  <div class="grid md:grid-cols-[1fr_2fr] gap-12">
    <div>
      <h2 class="text-xs font-mono text-primary tracking-[0.2em] uppercase">{s.tag}</h2>
      <p class="text-secondary text-sm mt-4 leading-relaxed">{s.lead}</p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {certs.length === 0 ? (
        <div class="sm:col-span-2 lg:col-span-3 p-6 border border-dashed border-primary/20">
          <p class="text-secondary text-sm font-mono tracking-tighter text-center">
            {s.empty} <a href="https://www.credly.com/users/nilo-lima-jr/badges" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">credly.com/users/nilo-lima-jr</a>.
          </p>
        </div>
      ) : (
        <>
          {certs.map(cert => (
            <div class="p-4 bg-primary/5 border border-primary/10 hover:border-primary/30 transition-all group h-24 flex flex-col justify-between overflow-hidden">
              <div class="flex justify-between items-start">
                <span class="text-[10px] font-mono text-primary opacity-60 uppercase">{cert.issuer}</span>
                <span class="text-[10px] font-mono text-secondary">{cert.year}</span>
              </div>
              <h3 class="text-sm text-accent font-semibold leading-snug group-hover:text-primary transition-colors line-clamp-2">
                {cert.name}
              </h3>
            </div>
          ))}
          <div class="sm:col-span-2 lg:col-span-3 p-4 border border-dashed border-primary/20 flex flex-wrap items-center gap-3">
            <span class="text-secondary text-xs font-mono">{s.verifyLabel}</span>
            <a href={CREDLY_PROFILE} target="_blank" rel="noopener noreferrer"
               class="px-3 py-1 text-xs font-mono text-primary border border-primary/30 hover:border-primary hover:bg-primary/10 transition-all">
              Credly ↗
            </a>
            <a href={MS_LEARN_PROFILE} target="_blank" rel="noopener noreferrer"
               class="px-3 py-1 text-xs font-mono text-primary border border-primary/30 hover:border-primary hover:bg-primary/10 transition-all">
              Microsoft Learn ↗
            </a>
            <a href={ACCREDIBLE_PROFILE} target="_blank" rel="noopener noreferrer"
               class="px-3 py-1 text-xs font-mono text-primary border border-primary/30 hover:border-primary hover:bg-primary/10 transition-all">
              Accredible ↗
            </a>
          </div>
          <div class="sm:col-span-2 lg:col-span-3 text-center py-3">
            <a href="/certificados" class="text-xs font-mono text-primary hover:underline tracking-widest uppercase">
              {s.viewAllCourses} →
            </a>
          </div>
        </>
      )}
    </div>
  </div>
</section>
