---
import { t, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = 'pt-BR' } = Astro.props;
const s = t(lang).contact;
const sectionId = lang === 'en' ? 'contact' : 'contato';
---
<footer id={sectionId} class="py-32 px-6 max-w-5xl mx-auto border-t border-primary/10 text-left">
  <div class="space-y-8">
    <h2 class="text-xs font-mono text-primary tracking-[0.2em] uppercase">{s.tag}</h2>
    <h3 class="text-3xl md:text-5xl font-bold tracking-tighter text-accent max-w-3xl">
      {s.titlePre} <span class="text-primary italic">{s.titleHighlight}</span>
    </h3>
    <p class="text-secondary text-lg max-w-2xl">
      {s.lead}
    </p>
    <div class="pt-12 border-t border-primary/10">
      <p class="text-[10px] font-mono text-primary/50 uppercase tracking-[0.2em] mb-4">{s.cvLabel}</p>
      <div class="flex flex-wrap gap-3">
        {s.cvItems.map(cv => (
          <a
            href={cv.file}
            download
            class="text-[10px] font-mono border border-primary/20 px-4 py-2 text-secondary hover:text-primary hover:border-primary/50 transition-colors flex items-center gap-2"
          >
            <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M5 20h14v-2H5v2zm7-18L5.33 9h3.84v4h5.66V9h3.84L12 2z"/></svg>
            {cv.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
