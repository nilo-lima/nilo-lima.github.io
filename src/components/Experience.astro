---
import { t, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = 'pt-BR' } = Astro.props;
const s = t(lang).experience;
const sectionId = lang === 'en' ? 'experience' : 'experiencia';
---
<section id={sectionId} class="py-16 px-6 max-w-5xl mx-auto border-t border-primary/10">
  <div class="grid md:grid-cols-[1fr_2fr] gap-12">
    <div>
      <h2 class="text-xs font-mono text-primary tracking-[0.2em] uppercase">{s.tag}</h2>
    </div>
    <div class="space-y-12">
      {s.items.map(exp => (
        <div class="relative pl-8 border-l border-primary/20 group">
          <div class="absolute -left-[5px] top-2 w-2 h-2 rounded-full bg-primary/40 group-hover:bg-primary transition-colors" aria-hidden="true"></div>
          <div class="flex flex-col md:flex-row md:justify-between mb-2">
            <h3 class="text-xl font-bold text-accent">{exp.role}</h3>
            <span class="text-xs font-mono text-secondary uppercase tracking-widest">{exp.period}</span>
          </div>
          <div class="text-sm font-mono text-primary/80 mb-4">{exp.company}</div>
          <div class="text-secondary text-base leading-relaxed">
            <Fragment set:html={exp.description} />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
