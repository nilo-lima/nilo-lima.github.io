---
import { t, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = 'pt-BR' } = Astro.props;
const s = t(lang).projects;
const sectionId = lang === 'en' ? 'projects' : 'projetos';
---
<section id={sectionId} class="py-16 px-6 max-w-5xl mx-auto border-t border-primary/10">
  <div class="grid md:grid-cols-[1fr_2fr] gap-12">
    <div>
      <h2 class="text-xs font-mono text-primary tracking-[0.2em] uppercase">{s.tag}</h2>
      <p class="text-secondary text-sm mt-4 leading-relaxed">{s.lead}</p>
    </div>
    <div class="space-y-12">
      {s.items.map(project => (
        <div class="group relative">
          <div class="flex flex-col md:flex-row md:items-baseline gap-4 mb-4">
            <h3 class="text-2xl font-bold text-accent group-hover:text-primary transition-colors">
              {project.title}
            </h3>
            <div class="flex flex-wrap gap-2">
              {project.tags.map(tag => (
                <span class="text-[10px] font-mono border border-primary/20 px-2 py-0.5 text-primary/70">
                  {tag}
                </span>
              ))}
            </div>
          </div>
          <p class="text-secondary text-lg mb-6 leading-relaxed">
            {project.description}
          </p>
          <a
            href={project.link}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-mono text-primary inline-flex items-center gap-2 hover:translate-x-1 transition-transform"
          >
            {s.cta} -&gt;
          </a>
        </div>
      ))}
      <div class="pt-4 border-t border-primary/5 text-sm font-mono text-secondary">
        {s.allRepos} <a href="https://github.com/nilo-lima" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">github.com/nilo-lima</a>.
      </div>
    </div>
  </div>
</section>
