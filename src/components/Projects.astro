---
import { getCollection } from 'astro:content';
import { t, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = 'pt-BR' } = Astro.props;
const s = t(lang).projects;
const sectionId = lang === 'en' ? 'projects' : 'projetos';

const pinned = (await getCollection('projects', ({ data }) => data.pinned))
  .sort((a, b) => a.data.order - b.data.order);
---
<section id={sectionId} class="py-16 px-6 max-w-5xl mx-auto border-t border-primary/10">
  <div class="grid md:grid-cols-[1fr_2fr] gap-12">
    <div>
      <h2 class="text-xs font-mono text-primary tracking-[0.2em] uppercase">{s.tag}</h2>
      <p class="text-secondary text-sm mt-4 leading-relaxed">{s.lead}</p>
    </div>
    <ul class="divide-y divide-primary/10" role="list">
      {pinned.map((project, i) => (
        <li>
          <a
            href={project.data.link}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-baseline gap-4 py-4 -mx-2 px-2 hover:bg-primary/[0.03] transition-colors"
          >
            <span class="text-[10px] font-mono text-primary/30 w-5 shrink-0 tabular-nums">
              {String(i + 1).padStart(2, '0')}
            </span>
            <span class="text-base font-bold text-accent group-hover:text-primary transition-colors flex-1 leading-snug">
              {project.data.title}
            </span>
            <span class="hidden sm:block text-[10px] font-mono text-secondary/50 shrink-0 text-right">
              {project.data.tags.slice(0, 3).join(' · ')}
            </span>
            <span class="text-primary/50 group-hover:text-primary font-mono text-sm shrink-0 group-hover:translate-x-0.5 transition-transform">
              →
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
  <div class="pt-6 border-t border-primary/5 flex justify-center text-xs font-mono">
    <a
      href={lang === 'en' ? '/en/projects/' : '/projetos'}
      class="text-primary hover:underline transition-colors"
    >
      {s.viewAll} -&gt;
    </a>
  </div>
</section>
