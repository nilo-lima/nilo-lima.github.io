---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (d: Date) =>
  d.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric', timeZone: 'UTC' });

const sourceLabel: Record<string, string> = {
  artigo: 'ARTIGO',
  github: 'GITHUB',
  linkedin: 'LINKEDIN',
};
---
<Layout title="Blog · Nilo Lima Jr" description="Notas sobre projetos do GitHub, artigos do LinkedIn e ensaios técnicos em Cloud, DevOps e IA aplicada a infraestrutura.">
  <Navbar />
  <main id="main">
    <section class="pt-32 pb-12 px-6 max-w-5xl mx-auto">
      <p class="font-mono text-primary text-sm tracking-widest" aria-hidden="true">CAT: BLOG_INDEX</p>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tighter text-accent mt-4 max-w-3xl">
        Notas de <span class="text-primary italic">infraestrutura, plataforma & IA</span>
      </h1>
      <p class="text-secondary text-lg max-w-2xl pt-4 leading-relaxed">
        Posts curtos sobre projetos publicados no GitHub, matérias e ensaios técnicos. Mais sinal, menos algoritmo.
      </p>
      <a href="/rss.xml" class="inline-flex items-center gap-2 mt-6 text-xs font-mono text-primary border border-primary/30 hover:border-primary px-3 py-1.5 transition-colors self-start" aria-label="Assinar feed RSS do blog">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
        RSS_FEED
      </a>
    </section>

    <section class="py-16 px-6 max-w-5xl mx-auto border-t border-primary/10">
      {posts.length === 0 ? (
        <p class="text-secondary text-lg">Ainda não há posts publicados. Volte em breve.</p>
      ) : (
        <ul class="space-y-12">
          {posts.map(post => (
            <li>
              <article class="group">
                <div class="flex flex-wrap items-baseline gap-3 mb-2">
                  <time datetime={post.data.pubDate.toISOString()} class="text-[10px] font-mono text-secondary uppercase tracking-widest">
                    {formatDate(post.data.pubDate)}
                  </time>
                  <span class="text-[10px] font-mono border border-primary/20 px-2 py-0.5 text-primary/70 uppercase tracking-widest">
                    {sourceLabel[post.data.source] ?? post.data.source}
                  </span>
                </div>
                <h2 class="text-2xl md:text-3xl font-bold text-accent group-hover:text-primary transition-colors">
                  <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
                </h2>
                <p class="text-secondary text-lg mt-3 leading-relaxed max-w-3xl">
                  {post.data.description}
                </p>
                <div class="flex flex-wrap gap-2 mt-4">
                  {post.data.tags.map(tag => (
                    <span class="text-[10px] font-mono border border-primary/10 px-2 py-0.5 text-secondary uppercase tracking-widest">#{tag}</span>
                  ))}
                </div>
                <a href={`/blog/${post.slug}/`} class="inline-flex items-center gap-2 mt-5 text-sm font-mono text-primary hover:translate-x-1 transition-transform">
                  LER_POST -&gt;
                </a>
              </article>
            </li>
          ))}
        </ul>
      )}
    </section>
  </main>
</Layout>
