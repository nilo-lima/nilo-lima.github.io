---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = (await getCollection('blog', ({ data }) => !data.draft))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return posts.map((post, index) => {
    const related = posts
      .filter(p => p.slug !== post.slug && p.data.tags.some(t => post.data.tags.includes(t)))
      .slice(0, 3);

    return {
      params: { slug: post.slug },
      props: {
        post,
        prev: posts[index + 1] ?? null,
        next: posts[index - 1] ?? null,
        related,
      },
    };
  });
}

interface Props {
  post: CollectionEntry<'blog'>;
  prev: CollectionEntry<'blog'> | null;
  next: CollectionEntry<'blog'> | null;
  related: CollectionEntry<'blog'>[];
}

const { post, prev, next, related } = Astro.props;
const { Content, headings } = await post.render();

const formatDate = (d: Date) =>
  d.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric', timeZone: 'UTC' });

const wordCount = post.body.trim().split(/\s+/).length;
const readingTime = Math.max(1, Math.round(wordCount / 200));

const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
const hasToc = tocHeadings.length >= 4;

const siteUrl = 'https://nilo-lima.github.io';
const postUrl = `${siteUrl}/blog/${post.slug}/`;
const linkedInShareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(postUrl)}`;

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',  item: siteUrl + '/'       },
    { '@type': 'ListItem', position: 2, name: 'Blog',  item: `${siteUrl}/blog/`  },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: postUrl      },
  ],
};

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: { '@type': 'Person', name: 'Nilo Lima Jr', url: siteUrl },
  publisher: { '@type': 'Person', name: 'Nilo Lima Jr', url: siteUrl },
  keywords: post.data.tags.join(', '),
  url: `${siteUrl}/blog/${post.slug}/`,
  inLanguage: 'pt-BR',
};
---
<Layout title={`${post.data.title} · Blog · Nilo Lima Jr`} description={post.data.description} ogImage={`/og/posts/${post.slug}.png`} articleJsonLd={articleJsonLd} breadcrumbJsonLd={breadcrumbJsonLd}>
  <Navbar />
  <main id="main">
    <!-- Barra de progresso de leitura -->
    <div id="reading-progress" aria-hidden="true" class="fixed top-0 left-0 z-[80] h-0.5 bg-primary pointer-events-none transition-none" style="width:0%"></div>

    <div class="px-6">
      <div class={hasToc
        ? "max-w-5xl mx-auto xl:grid xl:grid-cols-[1fr_220px] xl:gap-12 xl:items-start"
        : "max-w-3xl mx-auto"
      }>

        <article class="pt-32 pb-12 min-w-0">
          <a href="/blog" class="text-xs font-mono text-secondary hover:text-primary transition-colors uppercase tracking-widest">&lt;- VOLTAR_AO_BLOG</a>
          <header class="mt-8 space-y-4 border-b border-primary/10 pb-8">
            <div class="flex flex-wrap items-baseline gap-3">
              <time datetime={post.data.pubDate.toISOString()} class="text-[10px] font-mono text-secondary uppercase tracking-widest">
                {formatDate(post.data.pubDate)}
              </time>
              <span class="text-[10px] font-mono text-primary/50 uppercase tracking-widest">
                · {readingTime} min de leitura
              </span>
              {post.data.updatedDate && (
                <span class="text-[10px] font-mono text-secondary/60 uppercase tracking-widest">
                  · atualizado {formatDate(post.data.updatedDate)}
                </span>
              )}
            </div>
            <h1 class="text-3xl md:text-5xl font-bold tracking-tighter text-accent">{post.data.title}</h1>
            <p class="text-secondary text-lg leading-relaxed">{post.data.description}</p>
            <div class="flex flex-wrap gap-2 pt-2">
              {post.data.tags.map(tag => (
                <span class="text-[10px] font-mono border border-primary/10 px-2 py-0.5 text-secondary uppercase tracking-widest">#{tag}</span>
              ))}
            </div>
            {post.data.sourceUrl && (
              <p class="text-xs font-mono text-secondary pt-2">
                Fonte original:
                <a href={post.data.sourceUrl} class="text-primary hover:underline" target="_blank" rel="noopener noreferrer">{post.data.sourceUrl}</a>
              </p>
            )}

            <!-- Share buttons -->
            <div class="flex flex-wrap items-center gap-3 pt-5">
              <button
                id="share-copy-link"
                data-url={postUrl}
                class="flex items-center gap-1.5 text-[10px] font-mono border border-primary/20 px-3 py-1.5 text-secondary hover:text-primary hover:border-primary/40 transition-colors"
                aria-label="Copiar link do post"
              >
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                COPIAR_LINK
              </button>
              <a
                href={linkedInShareUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-1.5 text-[10px] font-mono border border-primary/20 px-3 py-1.5 text-secondary hover:text-primary hover:border-primary/40 transition-colors"
                aria-label="Compartilhar no LinkedIn"
              >
                <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                LINKEDIN
              </a>
            </div>
          </header>

          {hasToc && (
            <details class="xl:hidden mt-8 border border-primary/20 group">
              <summary class="px-4 py-3 text-xs font-mono text-primary tracking-[0.15em] uppercase cursor-pointer list-none flex justify-between items-center hover:bg-primary/5 transition-colors">
                // ÍNDICE
                <span class="opacity-40 group-open:rotate-180 transition-transform">▾</span>
              </summary>
              <nav class="px-4 pb-4 pt-2 space-y-1">
                {tocHeadings.map(h => (
                  <a
                    href={`#${h.slug}`}
                    class={`block text-xs font-mono py-0.5 transition-colors hover:text-primary ${h.depth === 3 ? 'pl-4 text-secondary/50' : 'text-secondary/70'}`}
                  >
                    {h.text}
                  </a>
                ))}
              </nav>
            </details>
          )}

          <div class="prose-invert mt-10">
            <Content />
          </div>

          <!-- Prev / Next -->
          <nav class="mt-16 pt-8 border-t border-primary/10 grid grid-cols-2 gap-4" aria-label="Navegação entre posts">
            {prev ? (
              <a href={`/blog/${prev.slug}/`} class="group flex flex-col gap-1 p-4 bg-white/[0.02] border border-primary/10 hover:border-primary/30 transition-colors">
                <span class="text-[10px] font-mono text-secondary uppercase tracking-widest">&lt;- anterior</span>
                <span class="text-sm font-bold text-accent group-hover:text-primary transition-colors line-clamp-2 leading-snug">{prev.data.title}</span>
              </a>
            ) : <div />}
            {next && (
              <a href={`/blog/${next.slug}/`} class="group flex flex-col gap-1 p-4 bg-white/[0.02] border border-primary/10 hover:border-primary/30 transition-colors text-right">
                <span class="text-[10px] font-mono text-secondary uppercase tracking-widest">próximo -&gt;</span>
                <span class="text-sm font-bold text-accent group-hover:text-primary transition-colors line-clamp-2 leading-snug">{next.data.title}</span>
              </a>
            )}
          </nav>

          <!-- Posts relacionados -->
          {related.length > 0 && (
            <section class="mt-12 pt-8 border-t border-primary/10" aria-label="Posts relacionados">
              <p class="text-[10px] font-mono text-primary tracking-[0.2em] uppercase mb-6">// Relacionados</p>
              <ul class="space-y-3">
                {related.map(r => (
                  <li>
                    <a href={`/blog/${r.slug}/`} class="group flex items-baseline gap-4 p-4 bg-white/[0.02] border border-primary/10 hover:border-primary/30 transition-colors">
                      <span class="text-[10px] font-mono text-secondary shrink-0 uppercase tracking-widest">
                        {r.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric', timeZone: 'UTC' })}
                      </span>
                      <span class="text-sm font-bold text-accent group-hover:text-primary transition-colors line-clamp-1 leading-snug flex-1">{r.data.title}</span>
                      <span class="text-primary/50 group-hover:text-primary font-mono text-sm shrink-0 group-hover:translate-x-0.5 transition-transform">→</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}

        </article>

        {hasToc && (
          <aside class="hidden xl:block" aria-label="Índice do post">
            <div class="sticky top-24 pt-32 pb-12">
              <p class="text-[10px] font-mono text-primary tracking-[0.2em] uppercase mb-4">// Índice</p>
              <nav id="toc-nav">
                {tocHeadings.map(h => (
                  <a
                    href={`#${h.slug}`}
                    class={`toc-link block text-xs font-mono py-1 leading-snug transition-colors hover:text-primary ${h.depth === 3 ? 'pl-3 text-secondary/40' : 'text-secondary/60'}`}
                  >
                    {h.text}
                  </a>
                ))}
              </nav>
            </div>
          </aside>
        )}

      </div>
    </div>
  </main>
</Layout>

<style is:global>
  .prose-invert {
    color: #94A3B8;
    font-size: 1.0625rem;
    line-height: 1.75;
  }
  .prose-invert h2 {
    color: #E2E8F0;
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
    scroll-margin-top: 6rem;
  }
  .prose-invert h3 {
    color: #E2E8F0;
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    scroll-margin-top: 6rem;
  }
  .toc-link.toc-active {
    color: #38BDF8;
    border-left: 2px solid #38BDF8;
    padding-left: 0.5rem;
  }
  .prose-invert p { margin: 1rem 0; }
  .prose-invert a {
    color: #38BDF8;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(56, 189, 248, 0.3);
  }
  .prose-invert a:hover { text-decoration-color: #38BDF8; }
  .prose-invert ul, .prose-invert ol {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }
  .prose-invert ul { list-style: disc; }
  .prose-invert ol { list-style: decimal; }
  .prose-invert li { margin: 0.4rem 0; }
  .prose-invert strong { color: #E2E8F0; }
  .prose-invert em { color: #38BDF8; font-style: italic; }
  .prose-invert code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9em;
    color: #38BDF8;
    background: rgba(56, 189, 248, 0.08);
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
  }
  .prose-invert pre {
    position: relative;
    border: 1px solid rgba(56, 189, 248, 0.1);
    border-radius: 6px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    font-size: 0.875rem;
  }
  .prose-invert pre code {
    background: transparent;
    color: inherit;
    padding: 0;
  }
  .copy-code-btn {
    position: absolute;
    top: 0.55rem;
    right: 0.55rem;
    z-index: 5;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    background: rgba(5, 5, 5, 0.9);
    border: 1px solid rgba(56, 189, 248, 0.2);
    color: rgba(148, 163, 184, 0.5);
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.15s, color 0.15s, border-color 0.15s;
    line-height: 1.5;
    border-radius: 2px;
  }
  pre:hover .copy-code-btn {
    opacity: 1;
  }
  .copy-code-btn:hover,
  .copy-code-btn.copied {
    color: #38BDF8;
    border-color: rgba(56, 189, 248, 0.45);
    opacity: 1;
  }
  .prose-invert blockquote {
    border-left: 2px solid #38BDF8;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: #E2E8F0;
    font-style: italic;
  }
  .prose-invert hr {
    border: none;
    border-top: 1px solid rgba(56, 189, 248, 0.1);
    margin: 2.5rem 0;
  }
  .prose-invert img {
    max-width: 100%;
    border-radius: 6px;
    margin: 1.5rem 0;
    border: 1px solid rgba(56, 189, 248, 0.1);
  }
</style>

<script>
  // ----- Barra de progresso de leitura -----
  const progressBar = document.getElementById('reading-progress');
  if (progressBar) {
    const onScroll = () => {
      const { scrollTop, scrollHeight, clientHeight } = document.documentElement;
      const pct = scrollHeight > clientHeight
        ? (scrollTop / (scrollHeight - clientHeight)) * 100
        : 0;
      progressBar.style.width = `${pct}%`;
    };
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  // ----- Botão copiar código -----
  document.querySelectorAll<HTMLElement>('.prose-invert pre').forEach(pre => {
    const btn = document.createElement('button');
    btn.className = 'copy-code-btn';
    btn.setAttribute('aria-label', 'Copiar código');
    btn.textContent = 'COPIAR';
    pre.appendChild(btn);

    btn.addEventListener('click', async () => {
      const code = pre.querySelector('code');
      const text = (code ?? pre).innerText;
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = text;
        Object.assign(ta.style, { position: 'fixed', opacity: '0' });
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        ta.remove();
      }
      btn.textContent = 'COPIADO!';
      btn.classList.add('copied');
      setTimeout(() => {
        btn.textContent = 'COPIAR';
        btn.classList.remove('copied');
      }, 2000);
    });
  });

  // ----- Copiar link do post -----
  const shareCopy = document.getElementById('share-copy-link');
  if (shareCopy) {
    shareCopy.addEventListener('click', async () => {
      const url = (shareCopy as HTMLElement).dataset.url ?? location.href;
      try {
        await navigator.clipboard.writeText(url);
      } catch {
        /* fallback: ignore */
      }
      const original = shareCopy.textContent;
      shareCopy.textContent = 'COPIADO!';
      setTimeout(() => { shareCopy.textContent = original; }, 2000);
    });
  }

  // ----- TOC ativo por scroll -----
  const tocNav = document.getElementById('toc-nav');
  if (tocNav) {
    const links = tocNav.querySelectorAll<HTMLAnchorElement>('.toc-link');
    const headingEls = document.querySelectorAll<HTMLElement>('.prose-invert h2, .prose-invert h3');

    const setActive = (id: string) => {
      links.forEach(a => {
        a.classList.toggle('toc-active', a.getAttribute('href') === `#${id}`);
      });
    };

    const observer = new IntersectionObserver(
      entries => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
            break;
          }
        }
      },
      { rootMargin: '-80px 0% -60% 0%', threshold: 0 }
    );

    headingEls.forEach(h => observer.observe(h));
  }
</script>
