---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const posts = (await getCollection('blog', ({ data }) => !data.draft))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .map(post => ({
      ...post,
      readingTime: Math.max(1, Math.round(post.body.trim().split(/\s+/).length / 200)),
    }));

  return paginate(posts, { pageSize: 6 });
}

const { page } = Astro.props;

const formatDate = (d: Date) =>
  d.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric', timeZone: 'UTC' });

const sourceLabel: Record<string, string> = {
  artigo: 'ARTIGO',
  github: 'GITHUB',
  linkedin: 'LINKEDIN',
};

const allTags = [...new Set(page.data.flatMap((p: any) => p.data.tags))].sort() as string[];

const pageTitle = page.currentPage === 1
  ? 'Blog · Nilo Lima Jr'
  : `Blog · Página ${page.currentPage} · Nilo Lima Jr`;
---
<Layout title={pageTitle} description="Notas sobre projetos do GitHub, artigos do LinkedIn e ensaios técnicos em Cloud, DevOps e IA aplicada a infraestrutura.">
  <Navbar />
  <main id="main">
    <section class="pt-32 pb-12 px-6 max-w-5xl mx-auto">
      <p class="font-mono text-primary text-sm tracking-widest" aria-hidden="true">CAT: BLOG_INDEX</p>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tighter text-accent mt-4 max-w-3xl">
        Notas de <span class="text-primary italic">infraestrutura, plataforma & IA</span>
      </h1>
      <p class="text-[10px] font-mono text-secondary/60 uppercase tracking-widest mt-3">{page.total} {page.total === 1 ? 'post' : 'posts'}</p>
      <p class="text-secondary text-lg max-w-2xl pt-4 leading-relaxed">
        Posts curtos sobre projetos publicados no GitHub, matérias e ensaios técnicos. Mais sinal, menos algoritmo.
      </p>
      <a href="/rss.xml" class="inline-flex items-center gap-2 mt-6 text-xs font-mono text-primary border border-primary/30 hover:border-primary px-3 py-1.5 transition-colors self-start" aria-label="Assinar feed RSS do blog">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
        RSS_FEED
      </a>
    </section>

    <section class="py-16 px-6 max-w-5xl mx-auto border-t border-primary/10">

      <!-- Filtro por tag -->
      <div class="flex flex-wrap gap-2 mb-12" id="tag-filters" role="group" aria-label="Filtrar por tag">
        <button
          data-tag="*"
          class="tag-btn text-[10px] font-mono border px-3 py-1 transition-colors border-primary/40 text-primary bg-primary/10"
          aria-pressed="true"
        >
          TODOS
        </button>
        {allTags.map(tag => (
          <button
            data-tag={tag}
            class="tag-btn text-[10px] font-mono border px-3 py-1 transition-colors border-primary/20 text-secondary hover:text-primary hover:border-primary/40"
            aria-pressed="false"
          >
            {tag}
          </button>
        ))}
      </div>

      {page.data.length === 0 ? (
        <p class="text-secondary text-lg">Ainda não há posts publicados. Volte em breve.</p>
      ) : (
        <ul class="space-y-4" id="posts-list">
          {page.data.map((post: any) => (
            <li
              class="post-item"
              data-tags={post.data.tags.map((t: string) => t.toLowerCase()).join(' ')}
            >
              <article class="group bg-white/[0.03] border border-primary/10 rounded-lg p-6 hover:border-primary/25 transition-colors">
                <div class="flex flex-wrap items-baseline gap-3 mb-2">
                  <time datetime={post.data.pubDate.toISOString()} class="text-[10px] font-mono text-secondary uppercase tracking-widest">
                    {formatDate(post.data.pubDate)}
                  </time>
                  <span class="text-[10px] font-mono border border-primary/20 px-2 py-0.5 text-primary/70 uppercase tracking-widest">
                    {sourceLabel[post.data.source] ?? post.data.source}
                  </span>
                  <span class="text-[10px] font-mono text-primary/50 uppercase tracking-widest">
                    {post.readingTime} min
                  </span>
                </div>
                <h2 class="text-xl md:text-2xl font-bold text-accent group-hover:text-primary transition-colors">
                  <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
                </h2>
                <p class="text-secondary text-sm mt-3 leading-relaxed max-w-3xl line-clamp-3">
                  {post.data.description}
                </p>
                <div class="flex flex-wrap gap-2 mt-4">
                  {post.data.tags.map((tag: string) => (
                    <button
                      class="tag-filter text-[10px] font-mono border border-primary/10 px-2 py-0.5 text-secondary uppercase tracking-widest hover:border-primary/40 hover:text-primary transition-colors cursor-pointer"
                      data-filter-tag={tag.toLowerCase()}
                    >#{tag}</button>
                  ))}
                </div>
                <a href={`/blog/${post.slug}/`} class="inline-flex items-center gap-2 mt-5 text-sm font-mono text-primary hover:translate-x-1 transition-transform">
                  LER_POST -&gt;
                </a>
              </article>
            </li>
          ))}
        </ul>
      )}

      <!-- Paginação -->
      {page.lastPage > 1 && (
        <nav class="flex items-center justify-between pt-16 border-t border-primary/10 mt-12" aria-label="Paginação do blog">
          <div>
            {page.url.prev ? (
              <a href={page.url.prev} class="text-xs font-mono text-primary border border-primary/30 hover:border-primary px-4 py-2 transition-colors">
                &lt;- ANTERIOR
              </a>
            ) : (
              <span class="text-xs font-mono text-secondary/30 border border-secondary/10 px-4 py-2 cursor-not-allowed">
                &lt;- ANTERIOR
              </span>
            )}
          </div>
          <span class="text-[10px] font-mono text-secondary/60 uppercase tracking-widest">
            {page.currentPage} / {page.lastPage}
          </span>
          <div>
            {page.url.next ? (
              <a href={page.url.next} class="text-xs font-mono text-primary border border-primary/30 hover:border-primary px-4 py-2 transition-colors">
                PRÓXIMO -&gt;
              </a>
            ) : (
              <span class="text-xs font-mono text-secondary/30 border border-secondary/10 px-4 py-2 cursor-not-allowed">
                PRÓXIMO -&gt;
              </span>
            )}
          </div>
        </nav>
      )}

    </section>
  </main>
</Layout>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
  const items = document.querySelectorAll<HTMLElement>('.post-item');

  function activateFilter(tag: string) {
    btns.forEach(b => {
      b.classList.remove('border-primary/40', 'text-primary', 'bg-primary/10');
      b.classList.add('border-primary/20', 'text-secondary');
      b.setAttribute('aria-pressed', 'false');
    });
    const target = [...btns].find(b => b.dataset.tag === tag) ?? btns[0];
    target.classList.add('border-primary/40', 'text-primary', 'bg-primary/10');
    target.classList.remove('border-primary/20', 'text-secondary');
    target.setAttribute('aria-pressed', 'true');

    items.forEach(item => {
      const tags = item.dataset.tags ?? '';
      const visible = tag === '*' || tags.split(' ').includes(tag.toLowerCase());
      item.style.display = visible ? '' : 'none';
    });
  }

  btns.forEach(btn => {
    btn.addEventListener('click', () => activateFilter(btn.dataset.tag ?? '*'));
  });

  document.querySelectorAll<HTMLButtonElement>('.tag-filter').forEach(tagBtn => {
    tagBtn.addEventListener('click', () => {
      activateFilter(tagBtn.dataset.filterTag ?? '*');
      document.getElementById('tag-filters')?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
  });
</script>
