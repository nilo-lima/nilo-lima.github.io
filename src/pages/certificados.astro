---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import rawData from '../data/certificados.json';

type CertFile  = { id: string; name: string };
type CertGroup = { folder: string; label: string; files: CertFile[] };

const groups = rawData as CertGroup[];

const title       = 'Cursos e Certificados | Nilo Lima Jr';
const description = 'Trilha contínua de aprendizado em Cloud, DevOps, Segurança, IA, dados e gestão — mais de 300 certificados verificáveis.';

function toSlug(str: string) {
  return str.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
}
---
<Layout title={title} description={description} lang="pt-BR">
  <Navbar lang="pt-BR" />
  <main id="main" class="pt-32 pb-16 px-6 max-w-5xl mx-auto">

    <div class="mb-10">
      <p class="text-xs font-mono text-primary tracking-[0.2em] uppercase">// Cursos &amp; Certificados</p>
      <h1 class="sr-only">Cursos e Certificados — Nilo Lima Jr</h1>
      <p class="text-secondary text-sm mt-3 leading-relaxed max-w-2xl">
        Trilha contínua de aprendizado em Cloud, DevOps, Segurança, IA, dados e gestão.
        Clique em qualquer certificado para visualizar no Google Drive.
      </p>
    </div>

    {groups.length === 0 ? (
      <div class="border border-dashed border-primary/20 p-8 text-center">
        <p class="text-secondary text-sm font-mono">Índice de certificados em construção.</p>
      </div>
    ) : (
      <>
        <div class="mb-8">
          <input
            id="cert-search"
            type="search"
            placeholder="Buscar certificado..."
            autocomplete="off"
            class="w-full max-w-md bg-transparent border border-primary/20 focus:border-primary/60 outline-none px-4 py-2 text-sm font-mono text-accent placeholder:text-secondary/40 transition-colors"
            aria-label="Buscar certificados"
          />
          <p id="cert-search-count" class="mt-2 text-xs font-mono text-secondary opacity-0 transition-opacity"></p>
        </div>

        <nav id="cert-nav" aria-label="Grupos de certificados" class="mb-12 flex flex-wrap gap-2">
          {groups.map(g => (
            <a
              href={`#${toSlug(g.label)}`}
              data-nav-group={toSlug(g.label)}
              class="px-3 py-1 text-xs font-mono text-secondary border border-primary/20 hover:border-primary/60 hover:text-primary transition-all"
            >
              {g.label}
              <span class="ml-1 opacity-40">({g.files.length})</span>
            </a>
          ))}
        </nav>

        <div id="cert-empty" class="hidden border border-dashed border-primary/20 p-8 text-center">
          <p class="text-secondary text-sm font-mono">Nenhum certificado encontrado.</p>
        </div>

        <div class="space-y-16">
          {groups.map(group => (
            <section id={toSlug(group.label)} data-group-section={toSlug(group.label)}>
              <h2 class="text-xs font-mono text-primary tracking-[0.2em] uppercase mb-6 pb-2 border-b border-primary/10">
                {group.label}
                <span class="text-secondary opacity-40 ml-2">({group.files.length})</span>
              </h2>
              <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
                {group.files.map(file => (
                  <a
                    href={`https://drive.google.com/file/d/${file.id}/view`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group flex flex-col bg-primary/5 border border-primary/10 hover:border-primary/40 transition-all overflow-hidden"
                    title={file.name}
                    data-cert-name={file.name.toLowerCase()}
                    data-cert-group={toSlug(group.label)}
                  >
                    <div class="aspect-[4/3] bg-primary/5 overflow-hidden">
                      <img
                        src={`/certs-thumbnails/${file.id}.png`}
                        alt={file.name}
                        loading="lazy"
                        width="400"
                        height="300"
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300 cert-thumb"
                      />
                    </div>
                    <div class="p-2">
                      <p class="text-[11px] text-secondary leading-snug line-clamp-2 group-hover:text-accent transition-colors">
                        {file.name}
                      </p>
                    </div>
                  </a>
                ))}
              </div>
            </section>
          ))}
        </div>
      </>
    )}
  </main>
</Layout>

<script>
  // Broken thumbnail fallback
  document.querySelectorAll<HTMLImageElement>('img.cert-thumb').forEach(img => {
    img.addEventListener('error', () => {
      const wrap = img.parentElement;
      if (!wrap) return;
      img.remove();
      wrap.innerHTML = '<div class="w-full h-full flex items-center justify-center"><span class="font-mono text-xs opacity-20 select-none">PDF</span></div>';
    });
  });

  // Search / filter
  const input   = document.getElementById('cert-search') as HTMLInputElement | null;
  const counter = document.getElementById('cert-search-count');
  const empty   = document.getElementById('cert-empty');
  const cards   = document.querySelectorAll<HTMLAnchorElement>('[data-cert-name]');
  const sections = document.querySelectorAll<HTMLElement>('[data-group-section]');
  const navPills = document.querySelectorAll<HTMLAnchorElement>('[data-nav-group]');

  input?.addEventListener('input', () => {
    const q = input.value.trim().toLowerCase();

    if (!q) {
      cards.forEach(c => c.style.display = '');
      sections.forEach(s => s.style.display = '');
      navPills.forEach(p => p.style.display = '');
      if (empty) empty.classList.add('hidden');
      if (counter) counter.style.opacity = '0';
      return;
    }

    let total = 0;
    const visibleGroups = new Set<string>();

    cards.forEach(card => {
      const match = card.dataset.certName!.includes(q);
      card.style.display = match ? '' : 'none';
      if (match) {
        total++;
        visibleGroups.add(card.dataset.certGroup!);
      }
    });

    sections.forEach(sec => {
      sec.style.display = visibleGroups.has(sec.dataset.groupSection!) ? '' : 'none';
    });

    navPills.forEach(pill => {
      pill.style.display = visibleGroups.has(pill.dataset.navGroup!) ? '' : 'none';
    });

    if (empty) empty.classList.toggle('hidden', total > 0);
    if (counter) {
      counter.textContent = `${total} certificado${total !== 1 ? 's' : ''} encontrado${total !== 1 ? 's' : ''}`;
      counter.style.opacity = '1';
    }
  });
</script>
