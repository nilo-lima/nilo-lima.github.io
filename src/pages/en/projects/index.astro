---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import { getCollection } from 'astro:content';

const lang = 'en' as const;

const projects = (await getCollection('projects'))
  .sort((a, b) => {
    if (a.data.pinned && !b.data.pinned) return -1;
    if (!a.data.pinned && b.data.pinned) return 1;
    if (a.data.pinned && b.data.pinned) return a.data.order - b.data.order;
    return a.data.title.localeCompare(b.data.title, 'en');
  });

const allTags = [...new Set(projects.flatMap(p => p.data.tags))].sort();
---
<Layout
  title="Projects · Nilo Lima Jr"
  description="Public repositories focused on reproducible infrastructure, automation and AI applied to operations."
  ogImage="/og/pages/en-projects.png"
  lang={lang}
>
  <Navbar lang={lang} />
  <main id="main">

    <section class="pt-32 pb-12 px-6 max-w-5xl mx-auto">
      <p class="font-mono text-primary text-sm tracking-widest" aria-hidden="true">CAT: PROJECTS_INDEX</p>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tighter text-accent mt-4 max-w-3xl">
        Projects in <span class="text-primary italic">infrastructure, platform & automation</span>
      </h1>
      <p class="text-secondary text-lg max-w-2xl pt-4 leading-relaxed">
        Public repositories focused on reproducibility, IaC, CI/CD and AI applied to operations. Featured projects are highlighted.
      </p>
    </section>

    <section class="py-8 px-6 max-w-5xl mx-auto border-t border-primary/10">

      <!-- Tag filter -->
      <div class="flex flex-wrap gap-2 mb-10" id="tag-filters" role="group" aria-label="Filter by technology">
        <button
          data-tag="*"
          class="tag-btn text-[10px] font-mono border px-3 py-1 transition-colors border-primary/40 text-primary bg-primary/10"
          aria-pressed="true"
        >
          ALL
        </button>
        {allTags.map(tag => (
          <button
            data-tag={tag}
            class="tag-btn text-[10px] font-mono border px-3 py-1 transition-colors border-primary/20 text-secondary hover:text-primary hover:border-primary/40"
            aria-pressed="false"
          >
            {tag}
          </button>
        ))}
      </div>

      <!-- Projects list -->
      <ul class="space-y-4" id="projects-list">
        {projects.map(project => (
          <li
            class="project-item"
            data-tags={project.data.tags.map(t => t.toLowerCase()).join(' ')}
          >
            <article class="group bg-white/[0.03] border border-primary/10 rounded-lg p-6 hover:border-primary/25 transition-colors">
              <div class="flex flex-wrap items-center gap-3 mb-2">
                {project.data.pubDate && (
                  <time datetime={project.data.pubDate.toISOString()} class="text-[10px] font-mono text-secondary uppercase tracking-widest">
                    {project.data.pubDate.toLocaleDateString('en', { day: '2-digit', month: 'short', year: 'numeric', timeZone: 'UTC' })}
                  </time>
                )}
                {project.data.pinned && (
                  <span class="text-[10px] font-mono text-primary border border-primary/40 px-2 py-0.5 uppercase tracking-widest">
                    ★ FEATURED
                  </span>
                )}
              </div>
              <h2 class="text-xl md:text-2xl font-bold text-accent group-hover:text-primary transition-colors">
                <a href={project.data.link} target="_blank" rel="noopener noreferrer">
                  {project.data.title}
                </a>
              </h2>
              <p class="text-secondary text-sm mt-3 leading-relaxed max-w-3xl line-clamp-3">
                {project.data.description}
              </p>
              <div class="flex flex-wrap gap-2 mt-4">
                {project.data.tags.map(tag => (
                  <button
                    class="tag-filter text-[10px] font-mono border border-primary/10 px-2 py-0.5 text-secondary uppercase tracking-widest hover:border-primary/40 hover:text-primary transition-colors cursor-pointer"
                    data-filter-tag={tag.toLowerCase()}
                  >#{tag}</button>
                ))}
              </div>
              <a
                href={project.data.link}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 mt-5 text-sm font-mono text-primary hover:translate-x-1 transition-transform"
              >
                OPEN_REPOSITORY -&gt;
              </a>
            </article>
          </li>
        ))}
      </ul>

      <!-- Footer -->
      <div class="pt-12 border-t border-primary/5 text-sm font-mono text-secondary">
        All repositories at <a href="https://github.com/nilo-lima" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">github.com/nilo-lima</a>.
      </div>

    </section>
  </main>
</Layout>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
  const items = document.querySelectorAll<HTMLElement>('.project-item');

  function activateFilter(tag: string) {
    btns.forEach(b => {
      b.classList.remove('border-primary/40', 'text-primary', 'bg-primary/10');
      b.classList.add('border-primary/20', 'text-secondary');
      b.setAttribute('aria-pressed', 'false');
    });
    const target = [...btns].find(b => b.dataset.tag === tag) ?? btns[0];
    target.classList.add('border-primary/40', 'text-primary', 'bg-primary/10');
    target.classList.remove('border-primary/20', 'text-secondary');
    target.setAttribute('aria-pressed', 'true');

    items.forEach(item => {
      const tags = item.dataset.tags ?? '';
      const visible = tag === '*' || tags.split(' ').includes(tag.toLowerCase());
      item.style.display = visible ? '' : 'none';
    });
  }

  btns.forEach(btn => {
    btn.addEventListener('click', () => activateFilter(btn.dataset.tag ?? '*'));
  });

  document.querySelectorAll<HTMLButtonElement>('.tag-filter').forEach(tagBtn => {
    tagBtn.addEventListener('click', () => {
      activateFilter(tagBtn.dataset.filterTag ?? '*');
      document.getElementById('tag-filters')?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
  });
</script>
